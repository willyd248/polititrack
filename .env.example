# PolitiTrack Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is listed in .gitignore.

# ─── Congress.gov API ────────────────────────────────────────────────────────
# Required. Get a free key at https://api.congress.gov/sign-up/
CONGRESS_API_KEY=your_congress_api_key_here

# ─── OpenFEC API ─────────────────────────────────────────────────────────────
# Required. Get a free key at https://api.open.fec.gov/developers/
FEC_API_KEY=your_fec_api_key_here

# ─── Site URL ────────────────────────────────────────────────────────────────
# Used for absolute URLs (Open Graph, sitemap, etc.)
# In development: http://localhost:3000
# In production: https://your-production-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── PostHog Analytics ───────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Sentry Error Monitoring ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_DSN=your_sentry_dsn
